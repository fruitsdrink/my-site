---
import ThemeToggle from './ThemeToggle.astro';
import { SITE } from '../site.config';

const nav = [
  { href: '/notes', label: '笔记' },
  { href: '/docs', label: '文档' },
  { href: '/resources', label: '资源' },
  { href: '/palettes', label: '配色' },
];

const pathname = Astro.url.pathname;
---

<header class="border-b border-border">
  <div class="mx-auto flex max-w-[1600px] flex-wrap items-center gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="font-display mr-auto text-xl font-bold text-fg">
      <span class="text-accent">{SITE.titleAccent}</span>{SITE.title.slice(1)}
    </a>
    <nav class="flex flex-wrap items-center gap-4 text-sm">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'transition-colors hover:text-accent',
            pathname.startsWith(item.href) ? 'text-accent' : 'text-muted',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <a
      href="/search"
      class="rounded border border-border bg-card px-3 py-1.5 text-sm text-muted transition-colors hover:border-accent hover:text-fg"
    >
      搜索
    </a>
    <ThemeToggle />
  </div>
</header>
