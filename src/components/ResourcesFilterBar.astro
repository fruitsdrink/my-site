---
import { resourcesFilterUrl, type ResourceFilters } from '../lib/resources';

interface Props {
  filters: ResourceFilters;
  count: number;
}

const { filters, count } = Astro.props;
const { type, category, tag } = filters;
const hasFilter = Boolean(type || category || tag);
---

{
  hasFilter && (
    <div class="mb-4 flex flex-wrap items-center gap-2 text-sm">
      <span class="text-muted">筛选：</span>
      {type && (
        <span class="inline-flex items-center gap-1 rounded border border-accent/40 bg-card py-0.5 pr-1 pl-2 font-mono text-xs text-accent">
          类型 {type}
          <a
            href={resourcesFilterUrl({ category, tag })}
            class="inline-flex h-5 w-5 items-center justify-center rounded text-muted transition-colors hover:bg-border hover:text-fg"
            aria-label={`移除类型筛选 ${type}`}
            title="移除此筛选"
          >
            ×
          </a>
        </span>
      )}
      {category && (
        <span class="inline-flex items-center gap-1 rounded border border-accent/40 bg-card py-0.5 pr-1 pl-2 font-mono text-xs text-accent">
          分类 {category}
          <a
            href={resourcesFilterUrl({ type, tag })}
            class="inline-flex h-5 w-5 items-center justify-center rounded text-muted transition-colors hover:bg-border hover:text-fg"
            aria-label={`移除分类筛选 ${category}`}
            title="移除此筛选"
          >
            ×
          </a>
        </span>
      )}
      {tag && (
        <span class="inline-flex items-center gap-1 rounded border border-accent/40 bg-card py-0.5 pr-1 pl-2 font-mono text-xs text-accent">
          标签 {tag}
          <a
            href={resourcesFilterUrl({ type, category })}
            class="inline-flex h-5 w-5 items-center justify-center rounded text-muted transition-colors hover:bg-border hover:text-fg"
            aria-label={`移除标签筛选 ${tag}`}
            title="移除此筛选"
          >
            ×
          </a>
        </span>
      )}
      <span class="text-muted">共 {count} 条</span>
      <a href="/resources" class="text-accent hover:underline">
        清除全部
      </a>
    </div>
  )
}