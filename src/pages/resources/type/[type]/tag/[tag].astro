---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import ResourcesFilterBar from '../../../../../components/ResourcesFilterBar.astro';
import ResourcesTable from '../../../../../components/ResourcesTable.astro';
import {
  filterResources,
  getSortedResources,
  isResourceType,
  RESOURCE_TYPES,
} from '../../../../../lib/resources';

export async function getStaticPaths() {
  const resources = await getSortedResources();
  const seen = new Set<string>();

  return RESOURCE_TYPES.flatMap((type) => {
    const tags = resources
      .filter((r) => r.data.type === type)
      .flatMap((r) => r.data.tags ?? [])
      .filter((tag, i, arr) => {
        const key = `${type}|${tag}`;
        if (seen.has(key)) return false;
        seen.add(key);
        return arr.indexOf(tag) === i;
      });

    return tags.map((tag) => ({ params: { type, tag } }));
  });
}

const { type, tag } = Astro.params;

if (!type || !tag || !isResourceType(type)) {
  return Astro.redirect('/resources');
}

const filters = { type, tag };
const resources = filterResources(await getSortedResources(), filters);
const pageTitle = `资源 · ${type} · 标签 ${tag}`;
---

<BaseLayout title={pageTitle}>
  <header class="mb-8">
    <h1 class="font-display text-2xl font-bold">资源</h1>
    <p class="mt-2 text-sm text-muted">
      类型 <span class="font-mono text-accent">{type}</span>
      {' · '}
      标签 <span class="font-mono text-accent">{tag}</span>
    </p>
  </header>

  <ResourcesFilterBar filters={filters} count={resources.length} />
  <ResourcesTable resources={resources} filters={filters} />
</BaseLayout>