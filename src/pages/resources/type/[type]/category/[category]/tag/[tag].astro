---
import BaseLayout from '../../../../../../../layouts/BaseLayout.astro';
import ResourcesFilterBar from '../../../../../../../components/ResourcesFilterBar.astro';
import ResourcesTable from '../../../../../../../components/ResourcesTable.astro';
import {
  filterResources,
  getResourceTypeCategoryPairs,
  getSortedResources,
  isResourceCategory,
  isResourceType,
} from '../../../../../../../lib/resources';

export async function getStaticPaths() {
  const pairs = await getResourceTypeCategoryPairs();
  const resources = await getSortedResources();
  const seen = new Set<string>();

  return pairs.flatMap(({ type, category }) => {
    const tags = resources
      .filter((r) => r.data.type === type && r.data.category === category)
      .flatMap((r) => r.data.tags ?? [])
      .filter((tag, i, arr) => {
        const key = `${type}|${category}|${tag}`;
        if (seen.has(key)) return false;
        seen.add(key);
        return arr.indexOf(tag) === i;
      });

    return tags.map((tag) => ({ params: { type, category, tag } }));
  });
}

const { type, category, tag } = Astro.params;

if (
  !type || !category || !tag ||
  !isResourceType(type) ||
  !isResourceCategory(category)
) {
  return Astro.redirect('/resources');
}

const filters = { type, category, tag };
const resources = filterResources(await getSortedResources(), filters);
const pageTitle = `资源 · ${type} · ${category} · ${tag}`;
---

<BaseLayout title={pageTitle}>
  <header class="mb-8">
    <h1 class="font-display text-2xl font-bold">资源</h1>
    <p class="mt-2 text-sm text-muted">
      类型 <span class="font-mono text-accent">{type}</span>
      {' · '}
      分类 <span class="font-mono text-accent">{category}</span>
      {' · '}
      标签 <span class="font-mono text-accent">{tag}</span>
    </p>
  </header>

  <ResourcesFilterBar filters={filters} count={resources.length} />
  <ResourcesTable resources={resources} filters={filters} />
</BaseLayout>