---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/dates';
import { getPublishedDocs } from '../../lib/collections';

const docs = (await getPublishedDocs()).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout title="文档">
  <h1 class="font-display mb-8 text-2xl font-bold">文档</h1>
  {docs.length === 0 ? (
    <p class="text-muted">暂无文档。</p>
  ) : (
    <ul class="space-y-3">
      {docs.map((entry) => (
        <li>
          <a
            href={`/docs/${entry.id}`}
            class="block rounded border border-border bg-card px-5 py-4 transition-colors hover:border-accent"
          >
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <strong class="text-fg">{entry.data.title}</strong>
              <time class="font-mono text-xs text-muted">{formatDate(entry.data.pubDate)}</time>
            </div>
            <p class="mt-1 text-sm text-muted">{entry.data.description}</p>
            {entry.data.toc && (
              <span class="mt-2 inline-block text-xs text-accent">含目录</span>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
