---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/dates';
import { getPublishedProjects } from '../../lib/collections';

const statusLabel: Record<string, string> = {
  active: '维护中',
  maintenance: '维护模式',
  archived: '已归档',
};

const projects = (await getPublishedProjects()).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout title="作品">
  <header class="mb-8">
    <h1 class="font-display text-2xl font-bold">作品</h1>
    <p class="mt-2 text-sm text-muted">个人开发与开源项目</p>
  </header>

  {
    projects.length === 0 ? (
      <p class="text-muted">暂无作品。</p>
    ) : (
      <ul class="space-y-4">
        {projects.map((entry) => (
          <li>
            <a
              href={`/projects/${entry.id}`}
              class="group flex flex-col overflow-hidden rounded border border-border bg-card transition-colors hover:border-accent sm:flex-row"
            >
              <div class="relative shrink-0 border-b border-border bg-bg sm:w-56 sm:border-b-0 sm:border-r lg:w-64">
                <img
                  src={entry.data.cover}
                  alt={entry.data.coverAlt ?? entry.data.title}
                  width={320}
                  height={200}
                  loading="lazy"
                  decoding="async"
                  class="aspect-[16/10] h-full w-full object-cover object-top transition-opacity group-hover:opacity-95"
                />
              </div>
              <div class="flex min-w-0 flex-1 flex-col px-5 py-5">
                <div class="flex flex-wrap items-baseline justify-between gap-2">
                  <strong class="font-display text-lg text-fg">{entry.data.title}</strong>
                  <span class="text-xs text-muted">{statusLabel[entry.data.status]}</span>
                </div>
                <p class="mt-2 text-sm text-muted">{entry.data.description}</p>
                {
                  entry.data.stack.length > 0 && (
                    <ul class="mt-3 flex flex-wrap gap-2">
                      {entry.data.stack.map((item) => (
                        <li>
                          <span class="rounded border border-border px-2 py-0.5 font-mono text-xs text-muted">
                            {item}
                          </span>
                        </li>
                      ))}
                    </ul>
                  )
                }
                <p class="mt-auto pt-3 font-mono text-xs text-muted">
                  {formatDate(entry.data.pubDate)}
                </p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
