---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DiscoveriesTable from '../../components/DiscoveriesTable.astro';
import { getSortedDiscoveries } from '../../lib/discoveries';

const discoveries = await getSortedDiscoveries();
---

<BaseLayout title="开源发现">
  <header class="mb-8">
    <h1 class="font-display text-2xl font-bold">开源发现</h1>
    <p class="mt-2 text-sm text-muted">
      收藏别人维护的开源仓库与产品（与个人作品、npm/服务类资源分开）
    </p>
  </header>

  <DiscoveriesTable discoveries={discoveries} />
</BaseLayout>
