{
  "name": "my-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check:palettes": "node scripts/check-palettes.mjs",
    "build": "npm run check:palettes && astro build && pagefind --site dist",
    "preview": "bun run build && wrangler dev",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "bun run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.0",
    "@astrojs/mdx": "6.0.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "6.4.0",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "wrangler": "^4.95.0"
  },
  "overrides": {
    "vite": "^7"
  }
}
